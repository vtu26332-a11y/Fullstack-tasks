<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Job Listings</title>
    <link rel="stylesheet" th:href="@{/css/app.css}" />
</head>
<body>
<div class="container card">
    <h1>Job Listings</h1>
    <a th:href="@{/student/dashboard}">Back to Dashboard</a>
    <input id="jobSearch" type="text" placeholder="Filter by keyword" />
    <table id="jobsTable">
        <thead><tr><th>Title</th><th>Category</th><th>Skills</th><th>Location</th><th>Experience</th></tr></thead>
        <tbody>
        <tr th:each="job : ${jobs}">
            <td th:text="${job.title}"></td>
            <td th:text="${job.category}"></td>
            <td th:text="${job.skills}"></td>
            <td th:text="${job.location}"></td>
            <td th:text="${job.experience}"></td>
        </tr>
        </tbody>
    </table>
</div>
<script th:src="@{/js/app.js}"></script>
</body>
</html>
